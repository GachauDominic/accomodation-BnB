# ROOMS
### Get all rooms
GET http://localhost:3000/auth/rooms/getall

###create a room
POST http://localhost:3000/auth/rooms/create
Content-Type: application/json

{
  "roomNumber": "8B",
  "roomDescription": "Studio apartment: one bathroom, one bedroom, one dinning room, balcony, dinner and breakfast included",
  "address": "Pamki Building, Kimathi way Nyeri down town",
  "maxGuest": 2,
  "pricePerNight": "2000.00"
}

{
  "roomNumber": "1A",
  "roomDescription": "Bedsitter: one bathroom, one bed, dinner and breakfast included",
  "address": "Pamki Building, Kimathi way Nyeri down town",
  "maxGuest": 2,
  "pricePerNight": "1500.00"
}

